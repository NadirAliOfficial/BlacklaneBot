<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Blacklane Auto-Accept Bot"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="by TEAM NAK"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginBottom="20dp" />

            <!-- Status indicators -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#F5F5F5"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvNotificationStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notification Access: NOT GRANTED"
                    android:textColor="#D32F2F"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvAccessibilityStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Accessibility Service: NOT GRANTED"
                    android:textColor="#D32F2F"
                    android:textSize="14sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnGrantNotification"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enable Notification Access"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnGrantAccessibility"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enable Accessibility Service"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Min hours before pickup:" />
                <EditText
                    android:id="@+id/etMinHours"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:inputType="numberDecimal"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Max hours before pickup:" />
                <EditText
                    android:id="@+id/etMaxHours"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="2"
                    android:inputType="numberDecimal"
                    android:gravity="center" />
            </LinearLayout>

            <Button
                android:id="@+id/btnSaveSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Save Settings"
                android:layout_marginBottom="24dp" />

            <TextView
                android:id="@+id/tvBotStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bot Status: Waiting for setup..."
                android:textSize="14sp"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/tvLastAction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last action: none"
                android:textSize="12sp"
                android:textColor="#AAAAAA"
                android:layout_marginTop="8dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp" />

            <!-- Live log panel -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Live Log"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#333333" />
                <Button
                    android:id="@+id/btnClearLog"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Clear"
                    android:textSize="11sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />
            </LinearLayout>

            <ScrollView
                android:id="@+id/logScroll"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="#111111"
                android:padding="8dp"
                android:layout_marginBottom="24dp">
                <TextView
                    android:id="@+id/tvLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="11sp"
                    android:textColor="#00FF00"
                    android:fontFamily="monospace" />
            </ScrollView>

            <!-- Contact footer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Support"
                android:textSize="12sp"
                android:textColor="#AAAAAA"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="theteamnak.com"
                android:textSize="13sp"
                android:textColor="#1565C0"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+92 304 2019543"
                android:textSize="13sp"
                android:textColor="#333333"
                android:layout_marginBottom="24dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Expiry overlay -->
    <LinearLayout
        android:id="@+id/expiredOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#EE000000"
        android:padding="40dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trial Period Ended"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your free trial has expired.\nContact us to continue using the bot."
            android:textSize="15sp"
            android:textColor="#CCCCCC"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <View
            android:layout_width="60dp"
            android:layout_height="1dp"
            android:background="#444444"
            android:layout_marginBottom="28dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="theteamnak.com"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#64B5F6"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+92 304 2019543"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WhatsApp / Call"
            android:textSize="12sp"
            android:textColor="#888888" />

    </LinearLayout>

</FrameLayout>
