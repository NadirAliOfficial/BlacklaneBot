<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Blacklane Auto-Accept Bot"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="24dp" />

    <!-- Status indicators -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F5F5F5"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvNotificationStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Notification Access: NOT GRANTED"
            android:textColor="#D32F2F"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvAccessibilityStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Accessibility Service: NOT GRANTED"
            android:textColor="#D32F2F"
            android:textSize="14sp" />
    </LinearLayout>

    <Button
        android:id="@+id/btnGrantNotification"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enable Notification Access"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnGrantAccessibility"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enable Accessibility Service"
        android:layout_marginBottom="24dp" />

    <!-- Settings -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Settings"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Min hours before pickup:" />
        <EditText
            android:id="@+id/etMinHours"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="1"
            android:inputType="numberDecimal"
            android:gravity="center" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Max hours before pickup:" />
        <EditText
            android:id="@+id/etMaxHours"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="2"
            android:inputType="numberDecimal"
            android:gravity="center" />
    </LinearLayout>

    <Button
        android:id="@+id/btnSaveSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save Settings"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/tvBotStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bot Status: Waiting for setup..."
        android:textSize="14sp"
        android:textColor="#888888" />

    <TextView
        android:id="@+id/tvLastAction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Last action: none"
        android:textSize="12sp"
        android:textColor="#AAAAAA"
        android:layout_marginTop="8dp" />

</LinearLayout>
